// Ralph Foulger's Academy of Real Estate — data model.
// Postgres on Railway. Migrations via `npx prisma db push` per project rules
// (no `prisma migrate` in this stack).

generator client {
  provider      = "prisma-client-js"
  // Railway / Docker uses node:24-alpine which ships OpenSSL 3.x. Without
  // these binary targets, the deployed Prisma engine fails to load
  // libssl.so.1.1 and every DB call 500s.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Pre-license students + admins. One row per human; multiple TimeEvents per row.
model User {
  id               String       @id @default(cuid())
  email            String       @unique
  passwordHash     String
  firstName        String
  lastName         String
  // `name` is kept as a composed display value (firstName + " " + lastName)
  // for back-compat with everything that reads it (emails, admin table, etc.).
  // The API populates it at write time; never write to it from outside.
  name             String
  phone            String?      // optional, E.164 or whatever the user types
  isAdmin          Boolean      @default(false)
  tier             String       @default("free") // free | standard | plus | solo
  emailVerifiedAt  DateTime?
  stripeCustomerId String?      @unique
  passedExamAt     DateTime?
  createdAt        DateTime     @default(now())
  lastSeenAt       DateTime     @default(now())
  timeEvents       TimeEvent[]
  emailTokens      EmailToken[]

  @@index([createdAt])
}

// Every email the academy sends OR receives is logged here. Outbound rows
// are written from src/lib/email.ts in the sendMail() wrapper. Inbound rows
// arrive via the /api/email/inbound webhook (Cloudflare Email Routing,
// Mailgun Routes, SendGrid Inbound Parse — any provider can post here).
//
// `category` lets the admin inbox tab into specific message types
// (verify-email / reset-password / welcome / support-reply / etc.) without
// pattern-matching subject lines.
model Message {
  id          String   @id @default(cuid())
  direction   String   // 'outbound' | 'inbound'
  category    String   @default("other") // verify | reset | welcome | support-reply | broadcast | inbound | other
  fromAddr    String
  toAddr      String
  subject     String
  bodyText    String
  bodyHtml    String?
  providerId  String?  // external message ID from Resend / inbound provider
  status      String   @default("queued") // queued | sent | delivered | bounced | received | read | replied
  errorMsg    String?
  // Optional linking to a user (the recipient for outbound, the sender for inbound)
  userId      String?
  // For inbound: which ticket / conversation this is replying to (set by the
  // webhook when subject contains a [RF-xxx] tag, or by manual admin link).
  ticketId    String?
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([direction, createdAt])
  @@index([category, createdAt])
  @@index([userId])
  @@index([ticketId])
}

// In-app support tickets surfaced on /admin/support. Created from the
// Report-a-Problem control in the Footer; works for anonymous visitors
// (captures their email + name inline) and signed-in users (linked via
// userId so we can see their study history alongside the report).
model SupportTicket {
  id          String    @id @default(cuid())
  userId      String?
  // Anonymous reports capture identity inline (not linked to a User row).
  reporterEmail String?
  reporterName  String?
  page        String    // pathname + search at time of report
  url         String    // full URL (helps reproduce)
  userAgent   String?
  category    String    @default("bug") // bug | typo | confusing | feature | billing | other
  description String
  // Workflow state
  status      String    @default("open") // open | in_progress | resolved | dismissed
  adminNotes  String?
  resolvedAt  DateTime?
  resolvedBy  String?   // admin user id
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([userId])
  @@index([createdAt])
}

// Email-bound tokens for verify-email + forgot-password flows. Stored as a
// hash so a DB leak does not yield live tokens. Single-use (usedAt set on
// consume) and short-lived (verify = 24h, reset = 1h).
model EmailToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   String   // 'verify' | 'reset'
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([purpose, expiresAt])
}

// One row per accrual tick from the client. Aggregated at read time for
// per-section breakdowns and total-hours-toward-60.
model TimeEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  path      String   // pathname like /free/lesson-1
  bucket    String   // chapters | flashcards | math | glossary | quizzes | tutor | practice | other
  seconds   Int      // bounded server-side to prevent abuse (max ~6s per heartbeat)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, bucket])
}
